# ═══════════════════════════════════════════════════════════════
# .gitignore — ZANKA Luxury Bags
# ═══════════════════════════════════════════════════════════════
# Protège les données sensibles et fichiers temporaires.
# NE JAMAIS commiter les vraies clés Firebase.
# ═══════════════════════════════════════════════════════════════

# ─── Variables d'environnement (CLÉS API FIREBASE) ─────────────
.env
.env.local
.env.production
.env.development

# ─── Fichiers de configuration sensibles ────────────────────────
firebase-config.local.json

# ─── Node / Dépendances ────────────────────────────────────────
node_modules/
package-lock.json

# ─── Firebase CLI / Déploiement ────────────────────────────────
.firebase/
firebase-debug.log

# ─── IDE et éditeurs ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ─── Build / dist (on déploie depuis la racine) ─────────────────
dist/
build/

# ─── Logs ───────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
