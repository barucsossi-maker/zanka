rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Refuser tout par defaut
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Images produits : lecture publique, ecriture admin
    match /products-images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;
    }

    // Avatars utilisateurs : le proprietaire peut uploader
    match /users/{userId}/avatar.{extension} {
      allow read: if true;
      allow write: if request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Videos hero : lecture publique, ecriture admin
    match /hero-videos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;
    }

    // Blog : lecture publique, ecriture admin
    match /blog/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;
    }

  }
}
